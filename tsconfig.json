{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",                /* Change this line */
    "moduleResolution": "bundler",      /* Ensures your bundler handles files correctly */
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": ["src"]
}
